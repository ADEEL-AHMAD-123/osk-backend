# Copy to .env and fill in. Never commit real secrets.

NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# Databases (native local services — no Docker)
MONGODB_URI=mongodb://127.0.0.1:27017/osk
REDIS_URL=redis://127.0.0.1:6379

# JWT — use long random strings in any non-local environment
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS is now reflect-Origin by default — any browser-supplied Origin
# is accepted, so you NEVER need to update this env when you add a new
# frontend domain. Auth is Bearer-only and protects sensitive routes.
#
# CORS_ORIGIN is still read, but it's now INFORMATIONAL only — the
# first entry is treated as "the canonical frontend origin" for
# outbound links (emails, payment redirect fallback). Add as many as
# you like; reordering changes the canonical pick.
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,https://osk-frontend-zeta.vercel.app
#
# CORS_BLOCKLIST is the only enforcement knob. Comma-separated list of
# origins (exact match OR `https://*.example.com` wildcard) that will
# be rejected at the CORS layer. Leave empty to accept everything.
CORS_BLOCKLIST=

# Media uploads — local | cloudinary
# `local` writes to ./uploads (dev default). `cloudinary` uploads to a
# Cloudinary cloud via the SDK; set the three keys below.
MEDIA_PROVIDER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=osk

# Transactional email — configured in /admin/email at runtime.
# Provider + credentials live in the EmailSettings collection
# (encrypted at rest). These env vars are read only as a BOOTSTRAP
# fallback for fresh deploys before the admin has opened the UI.
#
# Recommended: leave these blank, then paste a Resend key into
# /admin/email after deploy. Resend (api.resend.com) is HTTPS-only,
# so it works on Railway / Vercel / Render without SMTP-port
# allow-listing.
#
# Bootstrap fallback env vars:
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=OSK
# SMTP fallback (only used if EMAIL_PROVIDER=smtp in DB or env):
EMAIL_PROVIDER=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# Public app URL used in email links (verify, reset, etc.)
APP_BASE_URL=http://localhost:3000

# Public app URL used by payment success/cancel redirects
PUBLIC_APP_URL=http://localhost:3000

# Secret used to encrypt payment/provider credentials stored in DB.
# REQUIRED in production. Rotating it makes stored encrypted values unreadable
# until re-entered in Admin > Pricing.
OSK_SECRETS_KEY=

# Payment providers (optional bootstrap fallback)
# Prefer configuring these in Admin > Pricing so they are encrypted in DB.
# If both DB and env values are empty, non-production falls back to sandbox behavior.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Sandbox: https://api-m.sandbox.paypal.com
# Live:    https://api-m.paypal.com
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
PAYPAL_WEBHOOK_ID=

PAYSTACK_SECRET_KEY=

# WhatsApp Business API — integration-ready
WHATSAPP_BUSINESS_TOKEN=

# Error tracking (Sentry-compatible) — optional
SENTRY_DSN=
