# Copy to .env and fill in. Never commit real secrets.

NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# Databases (native local services — no Docker)
MONGODB_URI=mongodb://127.0.0.1:27017/osk
REDIS_URL=redis://127.0.0.1:6379

# JWT — use long random strings in any non-local environment
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS — the frontend origin (also used to build listing URLs)
CORS_ORIGIN=http://localhost:3000

# Media uploads — local | cloudinary
# `local` writes to ./uploads (dev default). `cloudinary` uploads to a
# Cloudinary cloud via the SDK; set the three keys below.
MEDIA_PROVIDER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=osk

# Transactional email — console | smtp
# `console` (default) just logs the message body + token to pino, which
# is fine until real email is needed. `smtp` uses nodemailer + any
# SMTP host (Gmail, Outlook, Mailtrap, etc. — no paid service required).
EMAIL_PROVIDER=console
EMAIL_FROM=OSK <no-reply@osk.dev>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# Public app URL used in email links (verify, reset, etc.)
APP_BASE_URL=http://localhost:3000

# WhatsApp Business API — integration-ready
WHATSAPP_BUSINESS_TOKEN=

# Error tracking (Sentry-compatible) — optional
SENTRY_DSN=
